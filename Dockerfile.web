ARG WEB_BASE_IMAGE=python:3.11-slim
FROM ${WEB_BASE_IMAGE}

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    BOLTZ_DATA_DIR=/data \
    BOLTZ_MODEL_HUB_DIR=/modelhub \
    PYTHONPATH=/app/src

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends python3 python3-pip python3-venv wget \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml README.md README.origin.md LICENSE /app/
COPY src /app/src

RUN python3 -m pip install --no-cache-dir --break-system-packages \
    fastapi "uvicorn[standard]" sqlalchemy "psycopg[binary]" redis python-multipart \
    requests pandas openpyxl rdkit

EXPOSE 8800

CMD ["python3", "-m", "boltz_web.main"]
