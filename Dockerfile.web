FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    BOLTZ_DATA_DIR=/data \
    BOLTZ_MODEL_HUB_DIR=/modelhub

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends wget \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml README.md README.origin.md LICENSE /app/
COPY src /app/src

RUN pip install --no-cache-dir -e .

EXPOSE 8080

CMD ["boltz-web"]

