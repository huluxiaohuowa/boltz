BOLTZ_WEB_PORT=8800
BOLTZ_POSTGRES_PASSWORD=boltz
BOLTZ_DEFAULT_ADMIN_USERNAME=admin
BOLTZ_DEFAULT_ADMIN_PASSWORD=admin123456
BOLTZ_USER_PROVISION_TOKEN=
REDIS_IMAGE=redis:7-alpine

# Host directory for user/project/asset files and Boltz model cache. This is
# bind-mounted to /data in the web container, so PDB/SDF/uploads/results and
# downloaded model files survive container rebuilds.
BOLTZ_DATA_HOST_DIR=./data

# Required: use the PGV postgres image built/released by apps/pgv.
# Example:
# PGV_POSTGRES_IMAGE=swr.cn-southwest-2.myhuaweicloud.com/ictrek/pgv:<tag>
PGV_POSTGRES_IMAGE=

# Optional. On hosts that cannot pull Docker Hub python images, set this to an
# internal mirror, a preloaded Python image, or a local web base image.
# Example for offline rebuilds after one successful deployment:
# WEB_BASE_IMAGE=boltz-web:base
WEB_BASE_IMAGE=python:3.11-slim

# Optional: local or shared Model Hub root mounted read-only into /modelhub.
MODEL_HUB_SHARED_MODELS_PATH=./.modelhub

# Optional CPU worker images. Use the AMD compose overlays on x86_64 servers
# and ARM overlays on aarch64 servers. CPU-only workers use amd_YYYYMMDD or
# arm_YYYYMMDD tags, not thor_YYYYMMDD tags.
BOLTZ_PROTEIN_PREP_ARM_IMAGE=boltz-protein-prep:arm-dev
BOLTZ_PROTEIN_PREP_AMD_IMAGE=boltz-protein-prep:amd-dev
PROTEIN_PREP_ARM_BASE_IMAGE=debian:bookworm-slim
PROTEIN_PREP_AMD_BASE_IMAGE=debian:bookworm-slim
BOLTZ_PREP_POLL_SECONDS=5

BOLTZ_LIGAND_PREP_ARM_IMAGE=boltz-ligand-prep:arm-dev
BOLTZ_LIGAND_PREP_AMD_IMAGE=boltz-ligand-prep:amd-dev
LIGAND_PREP_ARM_BASE_IMAGE=debian:bookworm-slim
LIGAND_PREP_AMD_BASE_IMAGE=debian:bookworm-slim
BOLTZ_LIGAND_PREP_POLL_SECONDS=3
